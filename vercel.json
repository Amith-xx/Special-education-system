{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "sems-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/auth/(.*)", "dest": "/index.js" },
    { "src": "/assets/(.*)", "dest": "/sems-frontend/dist/assets/$1" },
    { "src": "/(.*\\..*)", "dest": "/sems-frontend/dist/$1" },
    { "src": "/(.*)", "dest": "/sems-frontend/dist/index.html" }
  ]
}
